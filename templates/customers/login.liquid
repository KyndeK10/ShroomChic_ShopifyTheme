<!-- Customer Login Template -->
<div class="container py-24" style="max-width:32rem">
  <h1 class="font-serif gradient-text text-center" style="font-size:2.5rem;font-weight:700;margin-bottom:2rem">Login</h1>
  <div class="glass-card">
    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <div style="display:flex;flex-direction:column;gap:1.5rem">
        <div>
          <label for="email" class="form-label">Email</label>
          <input type="email" id="email" name="customer[email]" required class="form-input" autocomplete="email">
        </div>
        <div>
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="customer[password]" required class="form-input" autocomplete="current-password">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Sign In</button>
        <div class="text-center">
          <a href="/account/register" style="color:var(--color-primary);font-size:0.875rem">Create Account</a>
          <span class="text-stone-500" style="margin:0 0.5rem">·</span>
          <a href="#recover" style="color:var(--color-text-muted);font-size:0.875rem">Forgot Password?</a>
        </div>
      </div>
    {% endform %}
  </div>
</div>
