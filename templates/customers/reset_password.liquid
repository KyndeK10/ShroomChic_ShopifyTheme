<!-- Customer Reset Password Template -->
<div class="container py-24" style="max-width:32rem">
  <h1 class="font-serif gradient-text text-center" style="font-size:2.5rem;font-weight:700;margin-bottom:2rem">Reset Password</h1>
  <div class="glass-card">
    {% form 'reset_customer_password' %}
      {{ form.errors | default_errors }}
      <div style="display:flex;flex-direction:column;gap:1.5rem">
        <div>
          <label for="password" class="form-label">New Password</label>
          <input type="password" id="password" name="customer[password]" required class="form-input">
        </div>
        <div>
          <label for="password_confirmation" class="form-label">Confirm Password</label>
          <input type="password" id="password_confirmation" name="customer[password_confirmation]" required class="form-input">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Reset Password</button>
      </div>
    {% endform %}
  </div>
</div>
