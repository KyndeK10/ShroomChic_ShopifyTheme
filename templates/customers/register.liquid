<!-- Customer Register Template -->
<div class="container py-24" style="max-width:32rem">
  <h1 class="font-serif gradient-text text-center" style="font-size:2.5rem;font-weight:700;margin-bottom:2rem">Create Account</h1>
  <div class="glass-card">
    {% form 'create_customer' %}
      {{ form.errors | default_errors }}
      <div style="display:flex;flex-direction:column;gap:1.5rem">
        <div>
          <label for="first_name" class="form-label">First Name</label>
          <input type="text" id="first_name" name="customer[first_name]" required class="form-input">
        </div>
        <div>
          <label for="last_name" class="form-label">Last Name</label>
          <input type="text" id="last_name" name="customer[last_name]" required class="form-input">
        </div>
        <div>
          <label for="email" class="form-label">Email</label>
          <input type="email" id="email" name="customer[email]" required class="form-input">
        </div>
        <div>
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="customer[password]" required class="form-input">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Create Account</button>
        <p class="text-center"><a href="/account/login" style="color:var(--color-primary);font-size:0.875rem">Already have an account?</a></p>
      </div>
    {% endform %}
  </div>
</div>
