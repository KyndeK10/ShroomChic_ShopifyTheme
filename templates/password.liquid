<!-- Password Template -->
<div class="container text-center" style="max-width:32rem; padding: 2rem;">
  <h1 class="font-serif gradient-text" style="font-size:3rem;font-weight:700;margin-bottom:1.5rem">{{ shop.name }}</h1>
  <p class="text-stone-300" style="font-size:1.25rem;margin-bottom:2rem">We are weaving some extra magic behind the scenes. Come back soon!</p>
  
  <div class="glass-card">
    <h2 class="font-serif" style="font-size:1.5rem;font-weight:700;color:#fff;margin-bottom:1.5rem">Enter via password</h2>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <div style="display:flex;flex-direction:column;gap:1rem">
        <input type="password" name="password" id="Password" placeholder="Your password" class="form-input" autofocus>
        <button type="submit" class="btn btn-primary btn-full">Enter</button>
      </div>
    {% endform %}
  </div>
</div>
