<!-- Gift Card Template -->
<div class="container py-24 text-center">
  <h1 class="font-serif gradient-text" style="font-size:2.5rem;font-weight:700;margin-bottom:1.5rem">{{ 'gift_cards.issued.title' | t }}</h1>
  <p class="text-stone-300 mb-8" style="font-size:1.25rem">Here's your gift card!</p>
  
  <div class="glass-card glass-card-lg" style="max-width:32rem;margin:0 auto">
    <div style="margin-bottom:1.5rem">
      <img src="{{ 'gift-card/card.jpg' | shopify_asset_url }}" alt="Gift card" style="max-width:100%;border-radius:1rem">
    </div>
    
    <p style="font-size:2rem;font-weight:700;margin-bottom:0.5rem" class="gradient-text">{{ gift_card.balance | money }}</p>
    
    {% if gift_card.initial_value != gift_card.balance %}
      <p class="text-stone-500" style="font-size:0.875rem;margin-bottom:1rem">Initial value: {{ gift_card.initial_value | money }}</p>
    {% endif %}
    
    <div style="background:rgba(12,10,9,0.5);border:1px solid rgba(168,85,247,0.3);border-radius:0.75rem;padding:1rem;margin:1.5rem 0;font-family:var(--font-mono);font-size:1.25rem;letter-spacing:0.1em;color:#fff">
      {{ gift_card.code | format_code }}
    </div>
    
    {% if gift_card.expired %}
      <p style="color:#f87171;margin-bottom:1rem">This gift card has expired.</p>
    {% endif %}
    
    {% if gift_card.enabled %}
      <p class="text-stone-400" style="font-size:0.875rem;margin-bottom:1.5rem">
        {% if gift_card.expires_on %}
          Expires {{ gift_card.expires_on | date: '%B %d, %Y' }}
        {% else %}
          No expiry date
        {% endif %}
      </p>
    {% endif %}
    
    <a href="{{ shop.url }}" class="btn btn-primary">Start Shopping</a>
  </div>
</div>
