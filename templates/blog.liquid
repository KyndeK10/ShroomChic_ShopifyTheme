<!-- Blog Template -->
<div class="container py-24">
  <h1 class="font-serif gradient-text text-center" style="font-size:2.5rem;font-weight:700;margin-bottom:3rem">{{ blog.title }}</h1>
  <div class="product-grid">
    {% for article in blog.articles %}
      <div class="product-card">
        {% if article.image %}
          <a href="{{ article.url }}" class="product-card-image">
            <img src="{{ article.image | image_url: width: 800 }}" alt="{{ article.title }}" loading="lazy">
          </a>
        {% endif %}
        <div class="product-card-body">
          <h3 class="product-card-title" style="margin-bottom:0.5rem">
            <a href="{{ article.url }}">{{ article.title }}</a>
          </h3>
          <p class="text-stone-500" style="font-size:0.875rem;margin-bottom:0.75rem">{{ article.published_at | date: '%B %d, %Y' }}</p>
          <p class="text-muted" style="font-size:0.875rem">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
  {% if blog.articles.size == 0 %}
    <p class="text-center text-muted">No posts yet. Check back soon!</p>
  {% endif %}
</div>
