<!-- List Collections Template -->
<div class="container py-24">
  <div class="text-center mb-12">
    <h1 class="font-serif gradient-text" style="font-size:2.5rem;font-weight:700;margin-bottom:1rem">Collections</h1>
  </div>
  <div class="product-grid">
    {% for collection in collections %}
      {% unless collection.handle == 'frontpage' %}
        <a href="{{ collection.url }}" class="product-card" style="text-decoration:none">
          <div class="product-card-glow"></div>
          {% if collection.image %}
            <div class="product-card-image">
              <div class="product-card-image-overlay"></div>
              <img src="{{ collection.image | image_url: width: 800 }}" alt="{{ collection.title }}" loading="lazy">
            </div>
          {% endif %}
          <div class="product-card-body text-center">
            <h3 class="product-card-title">{{ collection.title }}</h3>
            <p class="product-card-category">{{ collection.products_count }} products</p>
          </div>
        </a>
      {% endunless %}
    {% endfor %}
  </div>
</div>
