<!-- Newsletter Section -->
<section class="relative z-10 mt-16 w-full max-w-4xl mx-auto px-4 pb-16 fade-in-up">
  <div class="bg-stone-900/50 backdrop-blur-xl border border-purple-500/20 rounded-3xl p-8 md:p-12 text-center shadow-2xl">
    <h2 class="text-3xl font-serif font-bold mb-4 text-white">
      {{ section.settings.heading | default: 'Join the Coven' }}
    </h2>
    <p class="text-stone-400 mb-8 max-w-md mx-auto">
      {{ section.settings.description | default: 'Subscribe for exclusive drops, secret sales, and psychedelic inspiration.' }}
    </p>

    {% form 'customer', id: 'newsletter-form', class: 'flex flex-col sm:flex-row gap-4 max-w-md mx-auto' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <input type="email" name="contact[email]" placeholder="Enter your email" class="flex-1 bg-stone-950/50 border border-purple-500/30 rounded-full px-6 py-3 text-white focus:outline-none focus:border-pink-500 focus:ring-1 focus:ring-pink-500 transition-all" required="">
      
      <button type="submit" class="px-8 py-3 bg-gradient-to-r from-pink-500 to-purple-600 text-white rounded-full font-medium hover:shadow-[0_0_20px_rgba(236,72,153,0.5)] transition-all">
        Subscribe
      </button>

      {% if form.posted_successfully? %}
        <p class="text-green-400 mt-4 text-sm text-center w-full">✨ Welcome to the coven!</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Coven" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Subscribe for exclusive drops, secret sales, and psychedelic inspiration." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
