<!-- Hero Section -->
<section class="hero-section relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-gradient-to-b from-stone-900 via-[#2a221f] to-[#1e1a18]">
  <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-purple-900/20 via-stone-950 to-stone-950 z-[-1]"></div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center pt-24 pb-16">
    <div class="mb-8 fade-in-up">
      {% if section.settings.logo_image != blank %}
        <img src="{{ section.settings.logo_image | image_url: width: 512 }}" alt="{{ shop.name }}" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-purple-500/30 shadow-[0_0_50px_rgba(168,85,247,0.4)]" width="256" height="256">
      {% elsif shop.brand.logo != blank %}
        <img src="{{ shop.brand.logo | image_url: width: 512 }}" alt="{{ shop.name }}" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-purple-500/30 shadow-[0_0_50px_rgba(168,85,247,0.4)]" width="256" height="256">
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-purple-500/30 shadow-[0_0_50px_rgba(168,85,247,0.4)]" width="256" height="256">
      {% endif %}
    </div>

    <h1 class="text-5xl md:text-7xl font-serif font-bold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-purple-400 via-pink-500 to-purple-600 fade-in-up">
      {{ section.settings.heading | default: 'Embrace the Magic' }}
    </h1>

    <p class="text-lg md:text-2xl text-stone-300 max-w-2xl mx-auto mb-10 font-light fade-in-up">
      {{ section.settings.subtitle | default: 'Psychedelic festival fashion and boho accessories designed for the free spirit.' }}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 fade-in-up">
      {% if section.settings.cta_primary_text != blank %}
        <a class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-white bg-purple-600 rounded-full overflow-hidden transition-all hover:scale-105 hover:shadow-[0_0_30px_rgba(168,85,247,0.6)]" href="{{ section.settings.cta_primary_link }}">
          <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-purple-600 to-pink-600 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
          <span class="relative flex items-center gap-2">
            {{ section.settings.cta_primary_text }} 
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right w-5 h-5 group-hover:translate-x-1 transition-transform" aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
          </span>
        </a>
      {% endif %}

      {% if section.settings.cta_secondary_text != blank %}
        <a class="group relative inline-flex items-center justify-center px-8 py-4 text-lg font-medium text-stone-300 border border-purple-500/50 rounded-full overflow-hidden transition-all hover:text-white hover:bg-purple-900/30" href="{{ section.settings.cta_secondary_link }}">
          <span class="relative flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-sparkles w-5 h-5 text-pink-400" aria-hidden="true"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path><path d="M20 2v4"></path><path d="M22 4h-4"></path><circle cx="4" cy="20" r="2"></circle></svg> 
            {{ section.settings.cta_secondary_text }}
          </span>
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Hero Logo Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Embrace the Magic"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Psychedelic festival fashion and boho accessories designed for the free spirit."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary Button Text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary Button Text",
      "default": "Limited Drops"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary Button Link",
      "default": "/pages/drops"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
