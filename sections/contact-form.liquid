<!-- Contact Form Section -->
<section class="relative py-24">
  {% if settings.enable_animated_background %}
    {% render 'animated-background', density: settings.particle_density %}
  {% endif %}

  <div class="container z-10" style="max-width:48rem">
    <div class="text-center mb-12" style="animation: fadeSlideUp 0.8s ease-out both">
      <h1 class="font-serif gradient-text" style="font-size:2.5rem;font-weight:700;margin-bottom:1.5rem">{{ section.settings.heading | default: 'Get in Touch' }}</h1>
      <p class="text-stone-300" style="font-size:1.25rem;font-weight:300;max-width:42rem;margin:0 auto">{{ section.settings.subtitle | default: "Have a question about an order, a custom design, or just want to say hi? Send me a message!" }}</p>
    </div>

    <!-- Story Highlights -->
    <div class="mb-12 fade-in-up">
      <div class="social-card-header">
        <div class="social-card-icon instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </div>
        <h3 class="social-card-title">Story Highlights</h3>
      </div>
      <div class="ig-stories">
        {% assign story_labels = '✨ BTS,🍄 Drops,🎨 Design,🎪 Fests,💜 Reviews' | split: ',' %}
        {% for label in story_labels %}
          <div class="ig-story">
            <div class="ig-story-ring"><div class="ig-story-inner"><div class="ig-story-dot" style="animation-delay:{{ forloop.index0 | times: 0.2 }}s"></div></div></div>
            <span class="ig-story-label">{{ label }}</span>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="glass-card glass-card-lg fade-in-up" style="box-shadow:0 0 50px rgba(168,85,247,0.1)">
      {% form 'contact', id: 'contact-form' %}
        {% if form.posted_successfully? %}
          <div class="contact-success">
            <div class="contact-success-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </div>
            <h2 class="font-serif" style="font-size:1.875rem;font-weight:700;color:#fff;margin-bottom:1rem">Message Sent!</h2>
            <p class="text-muted">Thanks for reaching out. I'll get back to you as soon as possible.</p>
          </div>
        {% else %}
          <div class="contact-form-wrap">
            <div class="contact-form-row">
              <div>
                <label for="name" class="form-label">Name</label>
                <input type="text" id="name" name="contact[name]" required class="form-input">
              </div>
              <div>
                <label for="email" class="form-label">Email</label>
                <input type="email" id="email" name="contact[email]" required class="form-input">
              </div>
            </div>
            <div>
              <label for="subject" class="form-label">Subject</label>
              <input type="text" id="subject" name="contact[subject]" required class="form-input">
            </div>
            <div>
              <label for="message" class="form-label">Message</label>
              <textarea id="message" name="contact[body]" rows="5" required class="form-input" style="resize:none"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-full btn-lg">
              Send Message
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Have a question about an order, a custom design, or just want to say hi? Send me a message!" }
  ],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}
