<!-- About Content Section -->
<section class="relative py-24">
  {% if settings.enable_animated_background %}
    {% render 'animated-background', density: settings.particle_density %}
  {% endif %}

  <div class="container z-10" style="max-width:56rem">
    <div class="text-center mb-12" style="animation: fadeSlideUp 0.8s ease-out both">
      <h1 class="font-serif gradient-text" style="font-size:2.5rem;font-weight:700;margin-bottom:1.5rem">{{ section.settings.heading | default: 'Meet Kristen' }}</h1>
      <p class="text-stone-300" style="font-size:1.25rem;font-weight:300;max-width:42rem;margin:0 auto">{{ section.settings.subtitle | default: 'The creative soul behind Shroom Chic Creations.' }}</p>
    </div>

    <div class="about-grid">
      <div class="about-image" style="animation: fadeSlideRight 0.8s ease-out 0.2s both">
        {% if section.settings.about_image %}
          <img src="{{ section.settings.about_image | image_url: width: 800 }}" alt="{{ section.settings.heading }}" width="800" height="{{ 800 | divided_by: section.settings.about_image.aspect_ratio | round }}">
        {% else %}
          <div style="width:100%;height:100%;background:linear-gradient(135deg,rgba(168,85,247,0.2),rgba(236,72,153,0.2))"></div>
        {% endif %}
        <div class="about-image-overlay"></div>
      </div>

      <div class="about-text" style="animation: fadeSlideLeft 0.8s ease-out 0.4s both">
        {{ section.settings.bio | default: "<p>Hi, I'm Kristen! Welcome to my magical corner of the internet. Shroom Chic Creations was born out of my deep love for festival culture, psychedelic art, and the intricate beauty of nature.</p><p>For years, I found myself searching for clothing and accessories that truly captured the essence of the experiences I had at music festivals—that feeling of connection, wonder, and unbridled self-expression. When I couldn't find exactly what I was looking for, I decided to create it myself.</p><p>Every design you see here is inspired by the mesmerizing patterns of mycelium, the vibrant colors of the forest floor, and the transformative power of art. I believe that what we wear is an extension of our inner magic.</p>" }}
        {% if section.settings.quote != blank %}
          <p class="about-quote">"{{ section.settings.quote }}"</p>
        {% endif %}
      </div>
    </div>

    {% if section.settings.show_video %}
      <div class="section-divider fade-in-up">
        {% render 'social-card', type: 'youtube', title: section.settings.video_title %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "About Content",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Meet Kristen" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "The creative soul behind Shroom Chic Creations." },
    { "type": "image_picker", "id": "about_image", "label": "About Image" },
    { "type": "richtext", "id": "bio", "label": "Bio Text" },
    { "type": "text", "id": "quote", "label": "Quote", "default": "Stay trippy, stay chic, and always embrace the magic within." },
    { "type": "checkbox", "id": "show_video", "label": "Show video section", "default": true },
    { "type": "text", "id": "video_title", "label": "Video Title", "default": "Our Story" }
  ],
  "presets": [{ "name": "About Content" }]
}
{% endschema %}
