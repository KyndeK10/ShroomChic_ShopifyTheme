<!-- Social Feeds Section -->
<section class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 fade-in-up">
  <div class="text-center mb-12">
    <h2 class="text-3xl md:text-4xl font-serif font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-500 mb-4">{{ section.settings.heading | default: 'Follow the Journey' }}</h2>
    <p class="text-stone-400 max-w-2xl mx-auto">{{ section.settings.subheading | default: 'Get inspired by our community and see the latest creations in action.' }}</p>
  </div>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    
    <!-- Instagram Grid -->
    <div class="">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-gradient-to-tr from-yellow-400 via-pink-500 to-purple-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram w-5 h-5 text-white" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </div>
        <h3 class="text-xl font-bold text-white">{{ section.settings.ig_title }}</h3>
      </div>
      <div class="bg-stone-900/40 backdrop-blur-md border border-purple-500/20 rounded-2xl p-6">
        <div class="grid grid-cols-3 gap-2">
          {% for i in (1..6) %}
          <div class="aspect-square bg-stone-800/80 rounded-lg overflow-hidden relative group cursor-pointer">
            <div class="absolute inset-0 bg-gradient-to-t from-purple-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-purple-500/10 to-pink-500/10"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-instagram w-6 h-6 text-white/70" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
            </div>
          </div>
          {% endfor %}
        </div>
        <p class="text-stone-500 text-sm text-center mt-4">{{ section.settings.ig_title }}</p>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="mt-3 flex items-center justify-center gap-2 text-pink-400 hover:text-pink-300 text-sm transition-colors">Follow on Instagram <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link w-3 h-3" aria-hidden="true"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg></a>
      </div>
    </div>

    <!-- TikTok Feed -->
    <div class="">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-black rounded-xl flex items-center justify-center border border-stone-700">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-music2 lucide-music-2 w-5 h-5 text-white" aria-hidden="true"><circle cx="8" cy="18" r="4"></circle><path d="M12 18V2l7 4"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white">{{ section.settings.tiktok_title }}</h3>
      </div>
      <div class="flex gap-4 overflow-x-auto pb-4">
        {% for i in (1..3) %}
        <div class="flex-shrink-0 w-[200px] aspect-[9/16] bg-stone-900/60 rounded-2xl border border-pink-500/20 flex flex-col items-center justify-center relative overflow-hidden group cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-t from-pink-900/20 to-transparent"></div>
          <div class="w-14 h-14 rounded-full bg-stone-800/80 flex items-center justify-center border border-pink-500/30 mb-3 group-hover:border-pink-400 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play w-6 h-6 text-pink-400 ml-1" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg>
          </div>
          <p class="text-stone-500 text-xs">TikTok #{{ i }}</p>
        </div>
        {% endfor %}
      </div>
    </div>

    <!-- YouTube Banner -->
    <div class="md:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-youtube w-5 h-5 text-white" aria-hidden="true"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"></path><path d="m10 15 5-3-5-3z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-white">{{ section.settings.yt_title }}</h3>
      </div>
      <div class="aspect-video bg-stone-900/60 rounded-2xl border border-purple-500/20 flex flex-col items-center justify-center relative overflow-hidden cursor-pointer group">
        <div class="absolute inset-0 bg-gradient-to-br from-red-900/10 to-purple-900/10"></div>
        <div class="w-20 h-20 rounded-full bg-red-600/20 flex items-center justify-center border-2 border-red-500/40 mb-4 group-hover:bg-red-600/30 group-hover:border-red-400 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-play w-8 h-8 text-red-400 ml-1" aria-hidden="true"><path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path></svg>
        </div>
        <p class="text-stone-400 text-sm">Brand Story Coming Soon</p>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Social Feeds",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow the Journey" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Get inspired by our community and see the latest creations in action." },
    { "type": "text", "id": "ig_title", "label": "Instagram Title", "default": "@shroomchiccreations" },
    { "type": "text", "id": "tiktok_title", "label": "TikTok Title", "default": "Viral Moments" },
    { "type": "text", "id": "yt_title", "label": "YouTube Title", "default": "Behind the Magic" }
  ],
  "presets": [{ "name": "Social Feeds" }]
}
{% endschema %}
