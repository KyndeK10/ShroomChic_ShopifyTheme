<!-- Drops Countdown Section -->
<section class="relative py-24">
  {% if settings.enable_animated_background %}
    {% render 'animated-background', density: settings.particle_density %}
  {% endif %}

  <div class="container z-10">
    <div class="text-center mb-12" style="animation: fadeSlideUp 0.8s ease-out both">
      <div class="drops-badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
        <span>Limited Edition</span>
      </div>
      <h1 class="font-serif gradient-text-wide" style="font-size:2.5rem;font-weight:700;margin-bottom:1.5rem">{{ section.settings.heading | default: 'The Midnight Mycelium Drop' }}</h1>
      <p class="text-stone-300" style="font-size:1.25rem;font-weight:300;max-width:42rem;margin:0 auto">{{ section.settings.description | default: 'Exclusive, small-batch designs that glow under UV light. Only 50 pieces of each item available.' }}</p>
    </div>

    <div class="countdown-card" data-countdown="{{ section.settings.drop_date }}">
      <div class="countdown-card-glow"></div>
      <div class="relative z-10">
        <h2 class="font-serif" style="font-size:1.5rem;font-weight:700;color:#fff;margin-bottom:2rem;display:flex;align-items:center;justify-content:center;gap:0.75rem">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          Unlocking In
        </h2>

        <div class="countdown-grid">
          {% assign units = 'Days,Hours,Minutes,Seconds' | split: ',' %}
          {% assign data_attrs = 'days,hours,minutes,seconds' | split: ',' %}
          {% for unit in units %}
            <div class="countdown-unit">
              <div class="countdown-value" data-{{ data_attrs[forloop.index0] }}>00</div>
              <span class="countdown-label">{{ unit }}</span>
            </div>
          {% endfor %}
        </div>

        <p class="text-stone-300 mb-8" style="max-width:28rem;margin-left:auto;margin-right:auto">{{ section.settings.signup_text | default: 'Sign up to get early access 1 hour before the general public. These will sell out fast.' }}</p>

        {% form 'customer', id: 'drops-vip-form' %}
          <div class="newsletter-form">
            <input type="hidden" name="contact[tags]" value="vip,drops">
            <input type="email" name="contact[email]" placeholder="Enter your email" required class="form-input form-input-round" style="background:rgba(12,10,9,0.8)">
            <button type="submit" class="btn btn-primary" style="font-weight:700;text-transform:uppercase;letter-spacing:0.05em">Get VIP Access</button>
          </div>
        {% endform %}
      </div>
    </div>

    <!-- Sneak Peek -->
    <div class="mt-24 text-center">
      <h3 class="font-serif" style="font-size:1.5rem;font-weight:700;color:#e7e5e4;margin-bottom:2rem">Sneak Peek</h3>
      <div class="sneak-peek-grid">
        {% for i in (1..3) %}
          <div class="sneak-peek-card">
            <div class="sneak-peek-overlay">
              <span class="sneak-peek-label">Classified</span>
            </div>
            {% if section.settings['sneak_image_' | append: i] %}
              <img src="{{ section.settings['sneak_image_' | append: i] | image_url: width: 600 }}" alt="Sneak peek {{ i }}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,rgba(168,85,247,0.2),rgba(236,72,153,0.2))"></div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Drops Countdown",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "The Midnight Mycelium Drop" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Exclusive, small-batch designs that glow under UV light. Only 50 pieces of each item available." },
    { "type": "text", "id": "drop_date", "label": "Drop Date (YYYY-MM-DDTHH:MM:SS)", "default": "", "info": "Leave blank for 3 days from now" },
    { "type": "textarea", "id": "signup_text", "label": "Signup Text", "default": "Sign up to get early access 1 hour before the general public. These will sell out fast." },
    { "type": "image_picker", "id": "sneak_image_1", "label": "Sneak Peek Image 1" },
    { "type": "image_picker", "id": "sneak_image_2", "label": "Sneak Peek Image 2" },
    { "type": "image_picker", "id": "sneak_image_3", "label": "Sneak Peek Image 3" }
  ],
  "presets": [{ "name": "Drops Countdown" }]
}
{% endschema %}
