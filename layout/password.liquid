<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} &mdash; Opening Soon</title>
  {{ 'shroom-chic.css' | asset_url | stylesheet_tag }}
  <style>
    :root {
      --color-primary: {{ settings.color_primary | default: '#a855f7' }};
      --color-secondary: {{ settings.color_secondary | default: '#ec4899' }};
      --color-background: {{ settings.color_background | default: '#0c0a09' }};
      --color-text: {{ settings.color_text | default: '#f5f5f4' }};
      --color-text-muted: {{ settings.color_text_muted | default: '#a8a29e' }};
      --font-heading: '{{ settings.font_heading | default: 'Playfair Display' }}', serif;
      --font-body: '{{ settings.font_body | default: 'Inter' }}', sans-serif;
    }
    body { background: var(--color-background); color: var(--color-text); font-family: var(--font-body); display: flex; flex-direction: column; min-height: 100vh; align-items: center; justify-content: center; }
  </style>
  {{ content_for_header }}
</head>
<body class="template-password">
  <main class="main-content" style="width:100%; height:100vh; display:flex; align-items:center; justify-content:center;">
    <!-- Radial gradient overlay -->
    <div class="main-gradient-overlay"></div>
    {{ content_for_layout }}
  </main>
</body>
</html>
