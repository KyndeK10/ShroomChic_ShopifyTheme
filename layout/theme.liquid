<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page_title }} — {{ shop.name }}</title>
  <meta name="description" content="{{ page_description | default: shop.description }}">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Theme CSS -->
  {{ 'shroom-chic.css' | asset_url | stylesheet_tag }}

  <!-- Theme Settings CSS Variables -->
  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-text-muted: {{ settings.color_text_muted }};
      --font-heading: '{{ settings.font_heading }}', ui-serif, Georgia, serif;
      --font-body: '{{ settings.font_body }}', ui-sans-serif, system-ui, sans-serif;
      --font-mono: 'Space Grotesk', ui-monospace, monospace;
    }
  </style>

  {{ content_for_header }}
</head>
<body>
  {% section 'header' %}

  <main class="main-content">
    <!-- Radial gradient overlay -->
    <div class="main-gradient-overlay"></div>
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <!-- Theme JS -->
  <script src="{{ 'shroom-chic.js' | asset_url }}" defer></script>
</body>
</html>
