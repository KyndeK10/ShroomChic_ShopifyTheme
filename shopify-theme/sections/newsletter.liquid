<!-- Newsletter Section -->
<section class="newsletter-section fade-in">
  <div class="glass-card glass-card-lg newsletter-card">
    <h2>{{ section.settings.heading | default: 'Join the Coven' }}</h2>
    <p class="text-muted mb-8">{{ section.settings.description | default: 'Subscribe for exclusive drops, secret sales, and psychedelic inspiration.' }}</p>
    {% form 'customer', id: 'newsletter-form' %}
      <div class="newsletter-form">
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="Enter your email" required class="form-input form-input-round">
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </div>
      {% if form.posted_successfully? %}
        <p style="color:#4ade80;margin-top:1rem;text-align:center">✨ Welcome to the coven!</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Coven" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Subscribe for exclusive drops, secret sales, and psychedelic inspiration." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
