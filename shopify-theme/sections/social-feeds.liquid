<!-- Social Feeds Section -->
<section class="social-section">
  <div class="container">
    <div class="social-section-header fade-in-up">
      <h2 class="gradient-text">{{ section.settings.heading | default: 'Follow the Journey' }}</h2>
      <p class="text-muted">{{ section.settings.subheading | default: 'Get inspired by our community and see the latest creations in action.' }}</p>
    </div>
    <div class="social-grid fade-in-up">
      {% render 'social-card', type: 'instagram', title: section.settings.ig_title %}
      {% render 'social-card', type: 'tiktok', title: section.settings.tiktok_title %}
      {% render 'social-card', type: 'youtube', title: section.settings.yt_title %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Feeds",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow the Journey" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Get inspired by our community and see the latest creations in action." },
    { "type": "text", "id": "ig_title", "label": "Instagram Title", "default": "@shroomchiccreations" },
    { "type": "text", "id": "tiktok_title", "label": "TikTok Title", "default": "Viral Moments" },
    { "type": "text", "id": "yt_title", "label": "YouTube Title", "default": "Behind the Magic" }
  ],
  "presets": [{ "name": "Social Feeds" }]
}
{% endschema %}
