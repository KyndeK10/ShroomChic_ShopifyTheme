<!-- Hero Section -->
<section class="hero">
  {% if settings.enable_animated_background %}
    {% render 'animated-background', density: settings.particle_density %}
  {% endif %}

  <div class="container z-10" style="text-align:center;display:flex;flex-direction:column;align-items:center;padding-top:6rem;padding-bottom:4rem">
    {% if section.settings.logo_image %}
      <img src="{{ section.settings.logo_image | image_url: width: 512 }}" alt="{{ shop.name }}" class="hero-logo">
    {% elsif shop.brand.logo %}
      <img src="{{ shop.brand.logo | image_url: width: 512 }}" alt="{{ shop.name }}" class="hero-logo">
    {% else %}
      <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="hero-logo">
    {% endif %}

    <h1 class="gradient-text-wide">{{ section.settings.heading | default: 'Embrace the Magic' }}</h1>

    <p class="hero-subtitle">{{ section.settings.subtitle | default: 'Psychedelic festival fashion and boho accessories designed for the free spirit.' }}</p>

    <div class="hero-ctas">
      {% if section.settings.cta_primary_text != blank %}
        <a href="{{ section.settings.cta_primary_link }}" class="btn btn-primary btn-lg">
          {{ section.settings.cta_primary_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {% endif %}
      {% if section.settings.cta_secondary_text != blank %}
        <a href="{{ section.settings.cta_secondary_link }}" class="btn btn-outline btn-lg">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-secondary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
          {{ section.settings.cta_secondary_text }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Hero Logo Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Embrace the Magic"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Psychedelic festival fashion and boho accessories designed for the free spirit."
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Primary Button Text",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "cta_primary_link",
      "label": "Primary Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Secondary Button Text",
      "default": "Limited Drops"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "Secondary Button Link",
      "default": "/pages/drops"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
